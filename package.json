    "demo:agent": "npx tsx examples/03-full-agent.ts",
    "demo:evolve": "npx tsx examples/04-evolve-demo.ts",
    "demo:workstation": "npx tsx examples/05-workstation.ts",
    "demo:brain": "npx tsx examples/06-developer-brain.ts",
    "demo:model": "npx tsx examples/07-model-recommend.ts",
    "demo:skill": "npx tsx examples/08-auto-skill.ts",
    "demo:subagent": "npx tsx examples/09-subagent.ts",
    "demo:roles": "npx tsx examples/10-role-search.ts",
    "demo:cli-chat": "npx tsx examples/11-cli-chat.ts",
    "demo:daemon": "npx tsx examples/12-daemon-cron.ts",
    "demo:auto-skill": "npx tsx examples/13-auto-skill-learning.ts",
    "demo:parallel": "npx tsx examples/14-subagent-parallel.ts",
    "demo:telegram": "npx tsx examples/15-telegram-bot.ts",
    "demo:tools": "npx tsx examples/16-built-in-tools.ts",
    "demo:mcp": "npx tsx examples/17-mcp-client.ts",
    "demo:full-yaml": "npx tsx examples/18-full-agent-yaml.ts",
    "demo:integration": "npx tsx examples/19-brain-with-agent.ts",
    "demo:cost": "npx tsx examples/20-cost-calculator.ts",
    "demo:seeds": "npx tsx examples/21-brain-seeds.ts",
    "demo:all": "npm run demo:basic && npm run demo:llm && npm run demo:evolve && npm run demo:agent && npm run demo:workstation && npm run demo:brain && npm run demo:model && npm run demo:roles"
  },
  "dependencies": {
    "agent-workstation": "^2.0.0",
    "agentkits": "^1.10.0",
    "deepbrain": "^1.11.2",
    "opc-agent": "^3.0.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
